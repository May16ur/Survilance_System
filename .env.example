# Backend binding
FRONTEND_ORIGIN=*

# Main app/camera config lives in project_config.json.
# Change server public_url, RTSP URLs, TCP pairs, and CP Plus DeviceID mapping there.
# PROJECT_CONFIG_PATH=C:\Users\aipc1\Desktop\Survilance_System\project_config.json

# MySQL on the client machine
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=vehicle_logsnew
MYSQL_CONNECTION_TIMEOUT=2

# Optional: map CP Plus device id / camera IP / lane / channel to app camera id
# CP_PLUS_CAMERA_MAP={"63f73009-afc1-78ea-8c7e-74":3,"192.168.1.110":3}

# Do not save the same recognized plate again from the same camera/lane inside this window.
CP_PLUS_DUPLICATE_PLATE_WINDOW_SEC=300

# Ignore camera backlog if SnapTime is older/newer than this many seconds. Set 0 to disable.
CP_PLUS_MAX_EVENT_AGE_SEC=120

# Vehicle Excel details
VEH_DETAILS_PATH=C:\Users\VICTUS\Desktop\Survilance_System\datacontrol\veh_details.xlsx

# Preview tuning
PREVIEW_STREAM_WIDTH=960
PREVIEW_STREAM_HEIGHT=540
PREVIEW_STREAM_JPEG_QUALITY=80
PREVIEW_STREAM_FPS=10
PREVIEW_BUFFER_DROP_FRAMES=2
